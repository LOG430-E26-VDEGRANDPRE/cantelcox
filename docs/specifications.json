                        "quantity": {
                          "type": "integer"
                        },
                        "description": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "idempotency_key": {
                    "type": "string",
                    "format": "utc-millisec"
                  }
                }
              },
              "example": {
                "user_id": 2,
                "items": [
                  {
                    "productOfferingRef": "SMGA54",
                    "quantity": 4,
                    "description": "Téléphone"
                  },
                  {
                    "productOfferingRef": "MOB001",
                    "quantity": 1,
                    "description": "Ligne de service mobile",
                    "numero": "5145855993"
                  }
                ],
                "idempotency_key": "1"
              }
            }
          }
        }
