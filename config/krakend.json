{
  "version": 3,
  "name": "CanTelcoX API Gateway",
  "timeout": "5s",
  "cache_ttl": "300s",
  "output_encoding": "json",
  "port": 8080,
  "extra_config": {
    "telemetry/opentelemetry": {
      "service_name": "krakend-api-gateway",
      "service_version": "1.0.0",
      "traces": {
        "exporters": {
          "otlp": [
            {
              "name": "jaeger",
              "host": "jaeger",
              "port": 4317,
              "endpoint": "/v1/traces"
            }
          ]
        }
      },
      "metrics": {
        "disabled": true
      }
    }
  },
  "endpoints": [
    {
      "endpoint": "/clients/party",
      "method": "POST",
      "input_headers": ["*"],
      "backend": [
        {
          "url_pattern": "/party",
          "host": ["http://svc_clients:5000"],
          "timeout": "5s"
        }
      ]
    },
    {
      "endpoint": "/clients/auth",
      "method": "POST",
      "input_headers": ["*"],
      "backend": [
        {
          "url_pattern": "/auth",
          "host": ["http://svc_clients:5000"],
          "timeout": "5s"
        }
      ]
    },
    {
      "endpoint": "/clients/party/{party_id}",
      "method": "GET",
      "input_headers": ["*"],
      "output_encoding": "json",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/party/{party_id}",
          "host": ["http://svc_clients:5000"],
          "timeout": "5s"
        }
      ]
    },
    {
      "endpoint": "/commandes/orders",
      "method": "POST",
      "input_headers": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/orders",
          "host": ["http://svc_commandes:5000"],
          "timeout": "5s"
        }
      ]
    },
    {
      "endpoint": "/store-manager-api/stocks",
      "method": "PUT",
      "input_headers": ["*"],
      "backend": [
        {
          "url_pattern": "/stocks",
          "host": ["http://store_manager:5000"],
          "timeout": "5s"
        }
      ]
    },
    {
      "endpoint": "/commandes/orders/{order_id}",
      "method": "GET",
      "input_headers": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/orders/{order_id}",
          "host": ["http://svc_commandes:5000"],
          "timeout": "5s"
        }
      ]
    },
    {
      "endpoint": "/facturation/payments/{payment_id}",
      "method": "POST",
      "input_headers": ["*"],
      "backend": [
        {
          "url_pattern": "/payments/process/{payment_id}",
          "host": ["http://payments_api:5009"],
          "timeout": "5s"
        }
      ]
    },
    {
      "endpoint": "/orchestration/commande",
      "method": "POST",
      "input_headers": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/saga/order",
          "host": ["http://svc_orchestration:5123"],
          "timeout": "5s"
        }
      ]
    },
    {
      "endpoint": "/catalogue/productofferings/{references}",
      "method": "POST",
      "input_headers": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/productoffering/{references}",
          "host": ["http://svc_catalogue:5000"],
          "timeout": "5s"
        }
      ]
    }
  ]
}