{
  "version": 3,
  "name": "CanTelcoX API Gateway",
  "timeout": "15s",
  "cache_ttl": "300s",
  "output_encoding": "json",
  "port": 8080,
  "extra_config": {
    "telemetry/opentelemetry": {
      "service_name": "krakend-api-gateway",
      "service_version": "1.0.0",
      "traces": {
        "exporters": {
          "otlp": [
            {
              "name": "jaeger",
              "host": "jaeger",
              "port": 4317,
              "endpoint": "/v1/traces"
            }
          ]
        }
      },
      "metrics": {
        "disabled": true
      }
    },
    "security/cors": {
      "allow_origins": [
        "*"
      ],
      "allow_methods": [
        "GET",
        "PATCH",
        "POST"
      ],
      "expose_headers": [
        "Content-Length",
        "Content-Type"
      ],
      "allow_headers": [
        "Accept-Language"
      ],
      "max_age": "12h",
      "allow_credentials": false,
      "debug": false
    }
  },
  "endpoints": [
    {
      "endpoint": "/clients/v1/party",
      "method": "POST",
      "input_headers": ["*"],
      "backend": [
        {
          "url_pattern": "/v1/party",
          "host": ["http://svc_clients:5000"],
          "timeout": "15s"
        }
      ]
    },
    {
      "endpoint": "/clients/v1/auth",
      "method": "POST",
      "input_headers": ["*"],
      "backend": [
        {
          "url_pattern": "/v1/auth",
          "host": ["http://svc_clients:5000"],
          "timeout": "15s"
        }
      ]
    },
    {
      "endpoint": "/clients/v1/party/{party_id}",
      "method": "GET",
      "input_headers": ["*"],
      "output_encoding": "json",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/v1/party/{party_id}",
          "host": ["http://svc_clients:5000"],
          "timeout": "15s"
        }
      ]
    },
    {
      "endpoint": "/commandes/v1/orders/{order_id}",
      "method": "GET",
      "input_headers": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/v1/orders/{order_id}",
          "host": ["http://svc_commandes:5000"],
          "timeout": "15s"
        }
      ]
    },
    {
      "endpoint": "/facturation/v1/paiement/{payment_id}",
      "method": "PATCH",
      "input_headers": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/v1/payments/process/{payment_id}",
          "host": ["http://svc_facturation:5000"],
          "timeout": "15s"
        }
      ]
    },
    {
      "endpoint": "/orchestration/v1/commande",
      "method": "POST",
      "input_headers": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/v1/saga/order",
          "host": ["http://svc_orchestration:5123"],
          "timeout": "15s"
        }
      ]
    },
    {
      "endpoint": "/catalogue/v1/offres",
      "method": "GET",
      "input_headers": ["*"],
      "backend": [
        {
          "url_pattern": "/v1/productofferings",
          "host": ["http://svc_catalogue:5000"],
          "timeout": "15s"
        }
      ]
    },
    {
      "endpoint": "/catalogue/v1/offres/{references}",
      "method": "GET",
      "input_headers": ["*"],
      "backend": [
        {
          "url_pattern": "/v1/productoffering/{references}",
          "host": ["http://svc_catalogue:5000"],
          "timeout": "15s"
        }
      ]
    },
    {
      "endpoint": "/facturation/v1/customerbill/{customerbill_id}",
      "method": "GET",
      "input_headers": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/v1/customerbills/{customerbill_id}",
          "host": ["http://svc_facturation:5000"],
          "timeout": "15s"
        }
      ]
    },
    {
      "endpoint": "/facturation/v1/client/{party_id}",
      "method": "GET",
      "input_headers": ["*"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/cantelcox/protocol/openid-connect/certs",
          "disable_jwk_security": true
        }
      },
      "backend": [
        {
          "url_pattern": "/v1/customerbills/party/{party_id}",
          "host": ["http://svc_facturation:5000"],
          "timeout": "15s"
        }
      ]
    }
  ]
}